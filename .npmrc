# Angular and ng-packagr need a flatter node_modules layout than pnpm's default.
shamefully-hoist=true

# Do not auto-install peerDependencies. They are declared explicitly in the catalog so
# that "what gets installed" is always a deliberate decision rather than something the
# package manager inferred. Exact pinning only means anything if this stays off.
auto-install-peers=false
strict-peer-dependencies=false

# Pin exactly when adding a dependency with `pnpm add` — never insert a caret.
save-exact=true
