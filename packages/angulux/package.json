{
    "name": "angulux",
    "version": "22.0.0-rc.0",
    "description": "Angular 22 UI component library — a curated community fork of the last MIT release of PrimeNG.",
    "license": "MIT",
    "private": false,
    "keywords": [
        "angular",
        "angular22",
        "ui",
        "components",
        "component-library",
        "datatable",
        "mit",
        "primeng-fork"
    ],
    "publishConfig": {
        "directory": "dist",
        "linkDirectory": false,
        "access": "public"
    },
    "scripts": {
        "build": "cross-env NODE_ENV=production PKG_DIR=. INPUT_DIR=src/ OUTPUT_DIR=dist/ npm run build:package",
        "build:package": "npm run check:license && npm run check:names && npm run build:prebuild && ng build angulux && npm run build:postbuild",
        "check:license": "node ../../tools/check-prime-license.mjs ../..",
        "check:names": "node ../../tools/codemod/scan-prime-names.mjs",
        "build:prebuild": "node ../../tools/build/prebuild.mjs",
        "build:postbuild": "node ../../tools/build/postbuild.mjs",
        "lint": "ng lint",
        "test:unit": "ng test angulux --watch=false --browsers=ChromeHeadless",
        "test:unit:watch": "ng test angulux"
    },
    "devDependencies": {
        "@types/jasmine": "5.1.13",
        "jasmine-core": "5.13.0",
        "karma": "~6.4.4",
        "karma-chrome-launcher": "~3.2.0",
        "karma-coverage": "~2.2.1",
        "karma-jasmine": "~5.1.0",
        "karma-jasmine-html-reporter": "~2.2.0",
        "tslib": "^2.8.1"
    },
    "peerDependencies": {
        "@angular/common": "catalog:angular22",
        "@angular/core": "catalog:angular22",
        "@angular/forms": "catalog:angular22",
        "@angular/router": "catalog:angular22",
        "@angular/platform-browser": "catalog:angular22",
        "rxjs": "^6.0.0 || ^7.8.1",
        "chart.js": "^4.0.0"
    },
    "dependencies": {
        "angulux-styled": "workspace:^",
        "angulux-utils": "workspace:^",
        "angulux-styles": "workspace:^",
        "angulux-motion": "workspace:^"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/anguless-com/angulux.git",
        "directory": "packages/angulux"
    },
    "bugs": {
        "url": "https://github.com/anguless-com/angulux/issues"
    },
    "peerDependenciesMeta": {
        "chart.js": {
            "optional": true
        }
    },
    "author": "Anguless",
    "homepage": "https://github.com/anguless-com/angulux"
}
