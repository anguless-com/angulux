{
    "name": "angulux-utils",
    "version": "1.0.0",
    "author": "PrimeTek Informatics",
    "description": "Framework-agnostic DOM, object and type utilities used by angulux.",
    "keywords": [
        "utilities",
        "helpers",
        "primeng",
        "primereact",
        "primevue",
        "primeuix"
    ],
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/anguless-com/angulux.git",
        "directory": "packages/angulux-utils"
    },
    "bugs": {
        "url": "https://github.com/anguless-com/angulux/issues"
    },
    "main": "./dist/index.mjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "exports": {
        ".": {
            "types": "./dist/index.d.mts",
            "import": "./dist/index.mjs",
            "default": "./dist/index.mjs"
        },
        "./*": {
            "types": "./dist/*/index.d.mts",
            "import": "./dist/*/index.mjs",
            "default": "./dist/*/index.mjs"
        }
    },
    "publishConfig": {
        "access": "public"
    },
    "sideEffects": false,
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "cross-env NODE_ENV=production tsup",
        "build:dev": "tsup --watch"
    },
    "engines": {
        "node": ">=12.11.0"
    },
    "private": false
}
