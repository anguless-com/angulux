{
    "compilerOptions": {
        "ignoreDeprecations": "6.0",
        "target": "ES2022",
        "lib": [
            "dom",
            "dom.iterable",
            "ES2022"
        ],
        "module": "ESNext",
        "moduleResolution": "bundler",
        "paths": {
            "@anguless/angulux-styled": [
                "./src/index.ts"
            ],
            "@anguless/angulux-styled/*": [
                "./src/*"
            ],
            "@anguless/angulux-utils": [
                "../angulux-utils/src/index.ts"
            ],
            "@anguless/angulux-utils/*": [
                "../angulux-utils/src/*"
            ]
        },
        "declarationMap": false,
        "noEmit": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "skipLibCheck": true
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}
